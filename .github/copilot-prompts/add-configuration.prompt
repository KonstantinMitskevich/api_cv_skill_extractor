# Add Configuration Settings

Add strongly-typed configuration settings to the application using the Options pattern.

## Requirements
1. Create configuration section in `appsettings.json`
2. Define strongly-typed configuration class
3. Register configuration in `Program.cs`
4. Inject `IOptions<T>` into services
5. Validate configuration on startup

## Step 1: Add Configuration to appsettings.json
```json
{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "PdfProcessing": {
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".pdf"],
    "TimeoutSeconds": 30,
    "MaxPageCount": 100
  },
  "AllowedHosts": "*"
}
```

## Step 2: Create Configuration Class
```csharp
namespace CV_extractor.Configuration;

/// <summary>
/// Configuration settings for PDF processing.
/// </summary>
public class PdfProcessingOptions
{
    /// <summary>
    /// Configuration section name in appsettings.json.
    /// </summary>
    public const string SectionName = "PdfProcessing";
    
    /// <summary>
    /// Maximum allowed file size in bytes (default: 10MB).
    /// </summary>
    public long MaxFileSizeBytes { get; init; } = 10_485_760;
    
    /// <summary>
    /// Allowed file extensions for upload.
    /// </summary>
    public string[] AllowedExtensions { get; init; } = new[] { ".pdf" };
    
    /// <summary>
    /// Timeout for PDF processing in seconds.
    /// </summary>
    public int TimeoutSeconds { get; init; } = 30;
    
    /// <summary>
    /// Maximum number of pages to process in a PDF.
    /// </summary>
    public int MaxPageCount { get; init; } = 100;
}
```

## Step 3: Register Configuration in Program.cs
```csharp
using CV_extractor.Configuration;

var builder = WebApplication.CreateBuilder(args);

// Register configuration
builder.Services.Configure<PdfProcessingOptions>(
    builder.Configuration.GetSection(PdfProcessingOptions.SectionName));

// Optional: Validate configuration on startup
builder.Services.AddOptions<PdfProcessingOptions>()
    .Bind(builder.Configuration.GetSection(PdfProcessingOptions.SectionName))
    .ValidateDataAnnotations()
    .ValidateOnStart();

// Register services
builder.Services.AddScoped<ISkillExtractorService, SkillExtractorService>();

var app = builder.Build();
```

## Step 4: Inject IOptions<T> into Service
```csharp
using Microsoft.Extensions.Options;

namespace CV_extractor;

public class SkillExtractorService : ISkillExtractorService
{
    private readonly ILogger<SkillExtractorService> _logger;
    private readonly PdfProcessingOptions _options;
    
    public SkillExtractorService(
        ILogger<SkillExtractorService> logger,
        IOptions<PdfProcessingOptions> options)
    {
        _logger = logger;
        _options = options.Value;
    }
    
    public (List<string> skills, string? error, int statusCode) ExtractSkillsFromPdf(IFormFile file)
    {
        // Use configuration
        if (file.Length > _options.MaxFileSizeBytes)
        {
            _logger.LogWarning("File size {Size} exceeds maximum {MaxSize}", 
                file.Length, _options.MaxFileSizeBytes);
            return (new List<string>(), 
                $"File size exceeds maximum allowed size of {_options.MaxFileSizeBytes} bytes", 
                StatusCodes.Status400BadRequest);
        }
        
        var extension = Path.GetExtension(file.FileName);
        if (!_options.AllowedExtensions.Contains(extension, StringComparer.OrdinalIgnoreCase))
        {
            return (new List<string>(), 
                $"Only {string.Join(", ", _options.AllowedExtensions)} files are supported", 
                StatusCodes.Status400BadRequest);
        }
        
        // Rest of processing
    }
}
```

## Configuration with Validation Attributes
```csharp
using System.ComponentModel.DataAnnotations;

namespace CV_extractor.Configuration;

public class PdfProcessingOptions
{
    public const string SectionName = "PdfProcessing";
    
    [Range(1024, 52428800)] // 1KB to 50MB
    public long MaxFileSizeBytes { get; init; } = 10_485_760;
    
    [Required]
    [MinLength(1)]
    public string[] AllowedExtensions { get; init; } = new[] { ".pdf" };
    
    [Range(1, 300)] // 1 second to 5 minutes
    public int TimeoutSeconds { get; init; } = 30;
    
    [Range(1, 1000)]
    public int MaxPageCount { get; init; } = 100;
}
```

## Custom Validation
```csharp
using Microsoft.Extensions.Options;

namespace CV_extractor.Configuration;

public class PdfProcessingOptionsValidator : IValidateOptions<PdfProcessingOptions>
{
    public ValidateOptionsResult Validate(string? name, PdfProcessingOptions options)
    {
        var errors = new List<string>();
        
        if (options.MaxFileSizeBytes < 1024)
            errors.Add("MaxFileSizeBytes must be at least 1KB");
        
        if (options.AllowedExtensions.Length == 0)
            errors.Add("At least one allowed extension must be specified");
        
        if (options.TimeoutSeconds < 1)
            errors.Add("TimeoutSeconds must be at least 1");
        
        return errors.Count > 0 
            ? ValidateOptionsResult.Fail(errors)
            : ValidateOptionsResult.Success;
    }
}

// Register validator in Program.cs
builder.Services.AddSingleton<IValidateOptions<PdfProcessingOptions>, PdfProcessingOptionsValidator>();
```

## Environment-Specific Configuration

### appsettings.Development.json
```json
{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "CV_extractor": "Trace"
    }
  },
  "PdfProcessing": {
    "MaxFileSizeBytes": 52428800,
    "TimeoutSeconds": 60
  }
}
```

### appsettings.Production.json
```json
{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "CV_extractor": "Information"
    }
  },
  "PdfProcessing": {
    "MaxFileSizeBytes": 5242880,
    "TimeoutSeconds": 15
  }
}
```

## Using IOptionsSnapshot for Reloadable Configuration
```csharp
public class SkillExtractorService : ISkillExtractorService
{
    private readonly IOptionsSnapshot<PdfProcessingOptions> _options;
    
    public SkillExtractorService(IOptionsSnapshot<PdfProcessingOptions> options)
    {
        _options = options; // Don't call .Value in constructor
    }
    
    public (List<string> skills, string? error, int statusCode) ExtractSkillsFromPdf(IFormFile file)
    {
        // Get current value (reloaded on each request if config file changes)
        var currentOptions = _options.Value;
        
        if (file.Length > currentOptions.MaxFileSizeBytes)
        {
            // ...
        }
    }
}
```

## Options Pattern Comparison

| Pattern | Lifetime | Reloads Config | Use Case |
|---------|----------|----------------|----------|
| `IOptions<T>` | Singleton | No | Static config, set once at startup |
| `IOptionsSnapshot<T>` | Scoped | Yes (per request) | Config that changes occasionally |
| `IOptionsMonitor<T>` | Singleton | Yes (real-time) | Config that changes frequently, background services |

## Configuration from Environment Variables
```bash
# Override configuration via environment variables
# Use double underscores for nested keys
export PdfProcessing__MaxFileSizeBytes=20971520
export PdfProcessing__TimeoutSeconds=45
```

```csharp
// In Program.cs, environment variables automatically override appsettings.json
var builder = WebApplication.CreateBuilder(args);
// builder.Configuration automatically includes environment variables
```

## User Secrets (Development Only)
```bash
# Initialize user secrets
dotnet user-secrets init

# Set secret values
dotnet user-secrets set "PdfProcessing:ApiKey" "secret-api-key-value"
dotnet user-secrets set "ConnectionStrings:Database" "Server=localhost;..."
```

## Checklist
- [ ] Configuration section added to appsettings.json
- [ ] Strongly-typed configuration class created
- [ ] Configuration registered in Program.cs
- [ ] IOptions<T> injected into services
- [ ] Validation attributes added (optional)
- [ ] Custom validator implemented (if needed)
- [ ] Environment-specific overrides in appsettings.{Environment}.json
- [ ] Default values set in configuration class
- [ ] XML documentation added to configuration properties
- [ ] Configuration validated on startup
